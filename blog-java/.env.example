SERVER_PORT=8080

MYSQL_URL=jdbc:mysql://127.0.0.1:3306/blog_java?useSSL=false&serverTimezone=UTC&characterEncoding=utf8&allowPublicKeyRetrieval=true
MYSQL_USERNAME=your_database_username
MYSQL_PASSWORD=your_database_password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_smtp_authorization_code
MAIL_FROM=your_email@example.com

JWT_SECRET=replace_with_your_long_random_secret
JWT_EXPIRATION_HOURS=72

UPLOAD_DIR=/www/wwwroot/myblog-java/uploads

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
